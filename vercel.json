{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
        "public/**",
        "src/destinations-data.json",
        "src/klook-city-pages.json",
        "src/xotelo-location-keys.json",
        "src/xotelo-hotel-seeds.json"
      ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "src/server.js" }]
}
